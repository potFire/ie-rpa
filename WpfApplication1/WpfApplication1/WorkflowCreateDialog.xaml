<Window x:Class="WpfApplication1.WorkflowCreateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建流程"
        Height="360"
        Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="20" FontWeight="SemiBold" Text="先选择流程类型，再填写基础信息" />
        <TextBlock Grid.Row="1" Margin="0,8,0,0" Foreground="#5B6470" Text="流程类型决定默认模板和后续发布归类。" TextWrapping="Wrap" />

        <TextBlock Grid.Row="2" Margin="0,18,0,4" Text="流程类型" />
        <ComboBox x:Name="WorkflowTypeComboBox" Grid.Row="2" Margin="90,14,0,0" Height="32" DisplayMemberPath="DisplayName" SelectedValuePath="Value" />

        <TextBlock Grid.Row="3" Margin="0,12,0,4" Text="流程名称" />
        <TextBox x:Name="NameTextBox" Grid.Row="3" Margin="90,8,0,0" Height="32" VerticalContentAlignment="Center" />

        <TextBlock Grid.Row="4" Margin="0,12,0,4" Text="适用角色" />
        <TextBox x:Name="RoleTextBox" Grid.Row="4" Margin="90,8,0,0" Height="32" VerticalContentAlignment="Center" />

        <Grid Grid.Row="5" Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="流程说明" />
            <TextBox x:Name="DescriptionTextBox"
                     Grid.Row="1"
                     Margin="0,6,0,0"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" />
        </Grid>

        <StackPanel Grid.Row="6" Margin="0,18,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Width="88" Margin="0,0,8,0" Click="CancelButton_OnClick" Content="取消" />
            <Button Width="88" Click="CreateButton_OnClick" Content="创建" />
        </StackPanel>
    </Grid>
</Window>
