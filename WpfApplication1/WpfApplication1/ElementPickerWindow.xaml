<Window x:Class="WpfApplication1.ElementPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="元素拾取器"
        Height="720"
        Width="1180"
        MinHeight="560"
        MinWidth="940"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="PagesComboBox"
                      Margin="0,0,12,0"
                      DisplayMemberPath="DisplayName"
                      SelectionChanged="PagesComboBox_OnSelectionChanged" />
            <Button Grid.Column="1"
                    Margin="0,0,12,0"
                    Padding="14,8"
                    Click="RefreshButton_OnClick"
                    Content="刷新页面" />
            <Button Grid.Column="2"
                    Margin="0,0,12,0"
                    Padding="14,8"
                    Click="PickButton_OnClick"
                    Content="开始页面拾取" />
            <Button Grid.Column="3"
                    Margin="0,0,12,0"
                    Padding="14,8"
                    Click="CopySelectorButton_OnClick"
                    Content="复制选择器" />
            <Button Grid.Column="4"
                    Padding="14,8"
                    Click="ApplySelectorButton_OnClick"
                    Content="写回当前步骤" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center"
                       Foreground="#5B6470"
                       Text="筛选关键字" />
            <TextBox x:Name="FilterTextBox"
                     Grid.Column="1"
                     Margin="12,0,0,0"
                     TextChanged="FilterTextBox_OnTextChanged" />
        </Grid>

        <DataGrid x:Name="ElementsDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  MouseDoubleClick="ElementsDataGrid_OnMouseDoubleClick"
                  SelectionChanged="ElementsDataGrid_OnSelectionChanged"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Width="90" Binding="{Binding TagName}" Header="标签" />
                <DataGridTextColumn Width="140" Binding="{Binding Id}" Header="Id" />
                <DataGridTextColumn Width="140" Binding="{Binding Name}" Header="Name" />
                <DataGridTextColumn Width="220" Binding="{Binding Text}" Header="文本" />
                <DataGridTextColumn Width="*" Binding="{Binding Selector}" Header="XPath 选择器" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3"
                   Margin="0,12,0,0"
                   Foreground="#5B6470"
                   Text="支持两种模式：1. 直接在表格里选现有元素并写回；2. 点击“开始页面拾取”，切到 IE 页面点目标元素，程序会自动计算 XPath 并写回当前步骤。" />
    </Grid>
</Window>