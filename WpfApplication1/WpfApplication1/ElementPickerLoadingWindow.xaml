<Window x:Class="WpfApplication1.ElementPickerLoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="正在启动页面拾取"
        Width="360"
        Height="190"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Padding="22"
            Background="White"
            BorderBrush="#D8E1EA"
            BorderThickness="1"
            CornerRadius="16">
        <StackPanel>
            <TextBlock FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#243648"
                       Text="正在加载页面拾取" />
            <TextBlock Margin="0,10,0,0"
                       Foreground="#5B6470"
                       Text="马上会进入拾取状态，请随后直接到 IE 页面点击目标元素。"
                       TextWrapping="Wrap" />
            <ProgressBar Margin="0,20,0,0"
                         Height="8"
                         IsIndeterminate="True"
                         Foreground="#1E88E5"
                         Background="#E6EEF7" />
            <TextBlock Margin="0,14,0,0"
                       HorizontalAlignment="Right"
                       Foreground="#7A8794"
                       Text="正在准备选择器环境..." />
        </StackPanel>
    </Border>
</Window>
